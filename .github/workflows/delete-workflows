name: Delete workflows

on:
  schedule:
    - cron: '0 1 * * 0'
  workflow_dispatch:

jobs:
  deploy:
    name: ❌ Cleanup
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@main
      
      - name: Delete workflows
        uses: Mattraks/delete-workflow-runs@main
        with:
          token: ${{ github.token }}
          repository: ${{ github.repository }}
          retain_days: 1
          keep_minimum_runs: 1
